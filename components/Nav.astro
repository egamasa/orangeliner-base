---
import logo from '../assets/orangeliner_logo_2022_accent.svg';

interface Props {
  subTitle?: string;
}

const { subTitle } = Astro.props;
const siteName = 'orangeliner.net';
const altText = subTitle ? `${siteName} ${subTitle}` : siteName;

interface NavLink {
  href: string;
  label: string;
}

interface Props {
  links?: NavLink[];
}

const defaultLinks: NavLink[] = [
  {
    href: 'https://orangeliner.net/contents/',
    label: 'Contents',
  },
  {
    href: 'https://orangeliner.net/apps/',
    label: 'Apps',
  },
  {
    href: 'https://orangeliner.net/tools/',
    label: 'Tools',
  },
  {
    href: 'https://blog.orangeliner.net',
    label: 'Blog',
  },
];

const { links = defaultLinks } = Astro.props;

const currentOrigin = Astro.site?.origin ?? '';

function resolve(url: string): string {
  if (currentOrigin && url.startsWith(currentOrigin)) {
    return new URL(url).pathname;
  }
  return url;
}
---

<nav class="flex items-center justify-between">
  <div>
    <a href="/" class="flex items-center gap-2 p-3">
      <img src={logo.src} alt={altText} class="h-8">
      {subTitle && <span class="font-bold text-sm">{subTitle}</span>}
    </a>
  </div>
  <div class="flex items-center text-lg p-0">
    {links.map((link) => (
        <a href={resolve(link.href)} class="p-3">{link.label}</a>
      ))}
    <button
      id="theme-toggle"
      type="button"
      class="p-3 cursor-pointer"
      aria-label="テーマ切替"
    >
      <span id="theme-icon-light" class="hidden">☀️</span>
      <span id="theme-icon-dark" class="hidden">🌙</span>
    </button>
  </div>
</nav>

<script>
const toggle = document.getElementById('theme-toggle');
const iconLight = document.getElementById('theme-icon-light');
const iconDark = document.getElementById('theme-icon-dark');
if (!toggle || !iconLight || !iconDark)
  throw new Error('Theme toggle elements not found');

function getTheme(): string {
  return localStorage.getItem('theme') || 'system';
}

function applyTheme(theme: string) {
  const root = document.documentElement;
  if (theme === 'dark') {
    root.setAttribute('data-theme', 'dark');
  } else if (theme === 'light') {
    root.setAttribute('data-theme', 'light');
  } else {
    root.removeAttribute('data-theme');
  }
  updateIcon();
}

function isDark(): boolean {
  const theme = getTheme();
  if (theme === 'dark') return true;
  if (theme === 'light') return false;
  return window.matchMedia('(prefers-color-scheme: dark)').matches;
}

function updateIcon() {
  if (!iconLight || !iconDark) return;
  if (isDark()) {
    iconLight.classList.remove('hidden');
    iconDark.classList.add('hidden');
  } else {
    iconLight.classList.add('hidden');
    iconDark.classList.remove('hidden');
  }
}

toggle.addEventListener('click', () => {
  const next = isDark() ? 'light' : 'dark';
  localStorage.setItem('theme', next);
  applyTheme(next);
});

applyTheme(getTheme());
</script>
