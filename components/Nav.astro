---
import logo from '../assets/orangeliner_logo_2022_accent.svg';

interface NavLink {
  href: string;
  label: string;
}

interface Props {
  subTitle?: string;
  links?: NavLink[];
}

const defaultLinks: NavLink[] = [
  {
    href: 'https://orangeliner.net/contents/',
    label: 'Contents',
  },
  {
    href: 'https://orangeliner.net/apps/',
    label: 'Apps',
  },
  {
    href: 'https://orangeliner.net/tools/',
    label: 'Tools',
  },
  {
    href: 'https://blog.orangeliner.net',
    label: 'Blog',
  },
];

const { subTitle, links = defaultLinks } = Astro.props;
const siteName = 'orangeliner.net';
const altText = subTitle ? `${siteName} ${subTitle}` : siteName;

const currentOrigin = Astro.site?.origin ?? '';

function resolve(url: string): string {
  if (currentOrigin && url.startsWith(currentOrigin)) {
    return new URL(url).pathname;
  }
  return url;
}
---

<nav class="relative flex flex-wrap items-center justify-between">
  <div>
    <a href="/" class="flex items-center gap-2 p-3 md:px-8">
      <img src={logo.src} alt={altText} class="h-6 md:h-8 w-auto max-w-[260px]">
      {subTitle && <span class="font-bold text-sm">{subTitle}</span>}
    </a>
  </div>

  <!-- Hamburger button (mobile only) -->
  <button
    id="menu-toggle"
    type="button"
    class="cursor-pointer p-3 md:hidden"
    aria-label="Menu"
    aria-expanded="false"
    aria-controls="nav-menu"
  >
    <svg
      id="menu-icon-open"
      class="h-6 w-6"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
      aria-hidden="true"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M4 6h16M4 12h16M4 18h16"
      />
    </svg>
    <svg
      id="menu-icon-close"
      class="hidden h-6 w-6"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
      aria-hidden="true"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M6 18L18 6M6 6l12 12"
      />
    </svg>
  </button>

  <!-- Nav links -->
  <div
    id="nav-menu"
    class="absolute top-full right-0 z-50 hidden border-t-2 border-[var(--color-header-border)] bg-[var(--color-header-bg)] md:relative md:flex md:items-center md:border-t-0 md:bg-transparent md:mr-8"
  >
    {links.map((link) => (
      <a href={resolve(link.href)} class="block px-3 py-2 text-lg">{link.label}</a>
    ))}
    <button
      id="theme-toggle"
      type="button"
      class="cursor-pointer p-3"
      aria-label="テーマ切替"
    >
      <span id="theme-icon-light" class="hidden">☀️</span>
      <span id="theme-icon-dark" class="hidden">🌙</span>
    </button>
  </div>
</nav>

<script>
// Hamburger menu toggle
const menuToggle = document.getElementById('menu-toggle');
const navMenu = document.getElementById('nav-menu');
const iconOpen = document.getElementById('menu-icon-open');
const iconClose = document.getElementById('menu-icon-close');

if (menuToggle && navMenu && iconOpen && iconClose) {
  menuToggle.addEventListener('click', () => {
    const expanded = menuToggle.getAttribute('aria-expanded') === 'true';
    menuToggle.setAttribute('aria-expanded', String(!expanded));
    navMenu.classList.toggle('hidden');
    iconOpen.classList.toggle('hidden');
    iconClose.classList.toggle('hidden');
  });
}

// Theme toggle
const toggle = document.getElementById('theme-toggle');
const iconLight = document.getElementById('theme-icon-light');
const iconDark = document.getElementById('theme-icon-dark');
if (!toggle || !iconLight || !iconDark)
  throw new Error('Theme toggle elements not found');

function getTheme(): string {
  return localStorage.getItem('theme') || 'system';
}

function applyTheme(theme: string) {
  const root = document.documentElement;
  if (theme === 'dark') {
    root.setAttribute('data-theme', 'dark');
  } else if (theme === 'light') {
    root.setAttribute('data-theme', 'light');
  } else {
    root.removeAttribute('data-theme');
  }
  updateIcon();
}

function isDark(): boolean {
  const theme = getTheme();
  if (theme === 'dark') return true;
  if (theme === 'light') return false;
  return window.matchMedia('(prefers-color-scheme: dark)').matches;
}

function updateIcon() {
  if (!iconLight || !iconDark) return;
  if (isDark()) {
    iconLight.classList.remove('hidden');
    iconDark.classList.add('hidden');
  } else {
    iconLight.classList.add('hidden');
    iconDark.classList.remove('hidden');
  }
}

toggle.addEventListener('click', () => {
  const next = isDark() ? 'light' : 'dark';
  localStorage.setItem('theme', next);
  applyTheme(next);
});

applyTheme(getTheme());
</script>
